HISTORY_FILE = os.path.expanduser("~/.slurm_usage_history.jsonl")

def log_usage(share_data):
    """Append current usage snapshot to history file."""
    if not share_data:
        return
    entry = {
        "ts": datetime.datetime.now().strftime("%Y-%m-%dT%H:%M:%S"),
        "effectv_usage": share_data["effectv_usage"],
        "norm_shares": share_data["norm_shares"],
        "fairshare": share_data["fairshare"],
        "raw_usage": share_data["raw_usage"],
    }
    try:
        with open(HISTORY_FILE, "a") as f:
            f.write(json.dumps(entry) + "\n")
    except IOError:
        pass

def load_history():
    """Load usage history from file."""
    entries = []
    try:
        with open(HISTORY_FILE, "r") as f:
            for line in f:
                line = line.strip()
                if line:
                    try:
                        entries.append(json.loads(line))
                    except (ValueError, KeyError):
                        pass
    except IOError:
        pass
    return entries

def resample(values, width):
    """Resample a list of values to exactly `width` points via linear interpolation."""
    if len(values) == width:
        return list(values)
    step = (len(values) - 1) / float(max(width - 1, 1))
    sampled = []
    for i in range(width):
        pos = i * step
        lo = int(pos)
        hi = min(lo + 1, len(values) - 1)
        frac = pos - lo
        sampled.append(values[lo] * (1 - frac) + values[hi] * frac)
    return sampled

def sparkline(values, width=60):
    """Render a single-row sparkline."""
    if not values:
        return " " * width
    blocks = " ▁▂▃▄▅▆▇█"
    mn, mx = min(values), max(values)
    rng = mx - mn if mx > mn else 1.0
    values = resample(values, width)
    result = ""
    for v in values:
        idx = int(round((v - mn) / rng * (len(blocks) - 1)))
        idx = max(0, min(len(blocks) - 1, idx))
        result += blocks[idx]
    return result

def tall_chart(values, width=60, height=8, color=CYAN):
    """Render a multi-row chart using block characters. Returns list of strings (top to bottom)."""
    if not values:
        return [" " * width] * height
    blocks = " ▁▂▃▄▅▆▇█"
    mn, mx = min(values), max(values)
    rng = mx - mn if mx > mn else 1.0
    values = resample(values, width)
    # Normalize to 0..1
    normed = [(v - mn) / rng for v in values]
    lines = []
    for row in range(height, 0, -1):
        # This row covers the range [(row-1)/height, row/height]
        row_lo = (row - 1) / float(height)
        row_hi = row / float(height)
        line = ""
        for v in normed:
            if v >= row_hi:
                line += "█"
            elif v > row_lo:
                # Partial fill within this row
                frac = (v - row_lo) / (row_hi - row_lo)
                idx = int(round(frac * (len(blocks) - 1)))
                idx = max(0, min(len(blocks) - 1, idx))
                line += blocks[idx]
            else:
                line += " "
        lines.append(line)
    return lines

def show_usage_history():
    """Display usage history chart."""
    entries = load_history()

    print()
    print("{}{}  Usage History  {}".format(BOLD, BG_BLUE, RESET))
    print()

    if len(entries) < 2:
        print("  Not enough data yet. Run the dashboard a few more times to build history.")
        print("  {}Data points collected: {}{}".format(DIM, len(entries), RESET))
        return

    # Parse timestamps and values
    timestamps = []
    usage_ratios = []
    raw_usages = []
    fairshares = []

    for e in entries:
        try:
            ts = datetime.datetime.strptime(e["ts"], "%Y-%m-%dT%H:%M:%S")
            timestamps.append(ts)
            ns = e.get("norm_shares", 0)
            eu = e.get("effectv_usage", 0)
            usage_ratios.append((eu / ns * 100) if ns > 0 else 0)
            raw_usages.append(e.get("raw_usage", 0))
            fairshares.append(e.get("fairshare", 0))
        except (ValueError, KeyError):
            pass

    if len(timestamps) < 2:
        print("  Not enough valid data points.")
        return

    first = timestamps[0].strftime("%b %d %H:%M")
    last = timestamps[-1].strftime("%b %d %H:%M")
    span = timestamps[-1] - timestamps[0]

    chart_w = 55
    chart_h = 8

    def render_chart(values, color, label_fmt="{:.1f}", unit=""):
        """Print a tall chart with y-axis labels."""
        mn_v = min(values)
        mx_v = max(values)
        lines = tall_chart(values, width=chart_w, height=chart_h, color=color)
        for i, line in enumerate(lines):
            # Y-axis labels: top, middle, bottom
            if i == 0:
                label = label_fmt.format(mx_v) + unit
            elif i == chart_h // 2:
                label = label_fmt.format((mn_v + mx_v) / 2) + unit
            elif i == chart_h - 1:
                label = label_fmt.format(mn_v) + unit
            else:
                label = ""
            print("  {}{:>10}{} {}{}{}{}".format(
                DIM, label, RESET,
                DIM + "│" + RESET, color, line, RESET
            ))
        # X-axis
        print("  {} {}{}{}".format(
            " " * 10, DIM + "└" + "─" * chart_w + RESET, "", ""
        ))
        print("  {}{} {:>{}}{}".format(
            DIM, " " * 11 + first, last, chart_w - len(first), RESET
        ))

    # Usage ratio over time
    section("Usage of Share Over Time")
    print()
    cur = usage_ratios[-1]
    render_chart(usage_ratios, CYAN, label_fmt="{:.1f}", unit="%")
    print("  Current: {}{:.1f}%{}  Min: {:.1f}%  Max: {:.1f}%".format(
        BOLD, cur, RESET, min(usage_ratios), max(usage_ratios)
    ))
    print()

    # Fairshare factor over time
    section("Fairshare Factor Over Time")
    print()
    render_chart(fairshares, GREEN, label_fmt="{:.4f}")
    print("  Current: {}{:.4f}{}  Min: {:.4f}  Max: {:.4f}".format(
        BOLD, fairshares[-1], RESET, min(fairshares), max(fairshares)
    ))
    print()

    # Raw usage over time
    section("Raw Usage (CPU-seconds) Over Time")
    print()
    render_chart(raw_usages, YELLOW, label_fmt="{:,.0f}")
    print("  Current: {}{:,}{}  Start: {:,}  Delta: {:,}".format(
        BOLD, raw_usages[-1], RESET, raw_usages[0], raw_usages[-1] - raw_usages[0]
    ))
    print()

    # Summary
    print("  {}Data points: {}  |  Span: {}{}".format(
        DIM, len(entries),
        "{} days".format(span.days) if span.days > 0 else "{:.1f} hours".format(span.total_seconds() / 3600),
        RESET
    ))
    print("  {}History file: {}{}".format(DIM, HISTORY_FILE, RESET))
    print()


